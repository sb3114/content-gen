# ── Non-sensitive configuration — safe to commit ──────────────────────────────
# Secrets (passwords, tokens, API keys) are injected via host shell env vars.
# See scripts/set-secrets.sh.example for the full secrets template.

# ── Gemini models ─────────────────────────────────────────────────────────────
GEMINI_PLANNING_MODEL=gemini-2.5-flash
GEMINI_WRITING_MODEL=gemini-2.5-pro

# ── WordPress (self-hosted, bondnow.net) ──────────────────────────────────────
WORDPRESS_SITE_URL=https://bondnow.net

# ── LinkedIn OAuth ────────────────────────────────────────────────────────────
# Must exactly match the redirect URI registered in your LinkedIn Developer App
LINKEDIN_REDIRECT_URI=http://localhost:8080/auth/linkedin/callback

# ── Database (non-secret config only) ────────────────────────────────────────
POSTGRES_USER=content
POSTGRES_DB=content_engine
# DATABASE_URL is constructed in docker-compose.yml using $POSTGRES_PASSWORD from the shell.
# Do NOT put DATABASE_URL here — it would embed the password in plain text.

# ── App ───────────────────────────────────────────────────────────────────────
DEBUG=false
# SECRET_KEY is injected from shell env — do NOT put it here.
