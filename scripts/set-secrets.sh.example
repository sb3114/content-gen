#!/usr/bin/env bash
# ─────────────────────────────────────────────────────────────────────────────
# Content Engine — Secrets Template
# ─────────────────────────────────────────────────────────────────────────────
#
# SETUP (one-time):
#   1. Copy this file to your home directory:
#        cp scripts/set-secrets.sh.example ~/content-engine-secrets.sh
#   2. Fill in all values below in the copy.
#   3. Lock down permissions so only you can read it:
#        chmod 600 ~/content-engine-secrets.sh
#   4. Optionally add to ~/.bashrc for auto-loading:
#        echo 'source ~/content-engine-secrets.sh' >> ~/.bashrc
#
# USAGE (before every docker compose up):
#   source ~/content-engine-secrets.sh
#   docker compose up --build
#
# NEVER commit the filled-in copy. This template file is safe to commit.
# ─────────────────────────────────────────────────────────────────────────────

# ── Gemini API ────────────────────────────────────────────────────────────────
export GEMINI_API_KEY=""

# ── WordPress (Application Password — no OAuth) ───────────────────────────────
# Generate in WP Admin → Users → Profile → Application Passwords
# The user must have Editor or Administrator role to create posts.
export WORDPRESS_USERNAME="contentAutomation"
export WORDPRESS_APP_PASSWORD=""        # e.g. "xxxx xxxx xxxx xxxx xxxx xxxx"

# ── LinkedIn OAuth ────────────────────────────────────────────────────────────
# From https://www.linkedin.com/developers/apps — your app's Auth settings.
export LINKEDIN_CLIENT_ID=""
export LINKEDIN_CLIENT_SECRET=""

# These three are auto-filled when you complete OAuth at /auth/linkedin.
# After the callback, the app prints them — paste them here for persistence.
export LINKEDIN_ACCESS_TOKEN=""
export LINKEDIN_PERSON_URN=""           # e.g. urn:li:person:XXXXXXXX
export LINKEDIN_TOKEN_ISSUED_AT=""      # ISO datetime, e.g. 2026-05-11T22:00:00+00:00

# ── Database ──────────────────────────────────────────────────────────────────
export POSTGRES_PASSWORD="change-me-strong-password"

# ── App ───────────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
export SECRET_KEY=""
